// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  username      String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("TEACHER")
  school        String?
  tokens        Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  questionSets  QuestionSet[]
  history       GameHistory[]
  classrooms    Classroom[]
  students      Student[]
  notifications Notification[]
  boardPosts    BoardPost[]
  boardComments BoardComment[]
  boardReactions BoardReaction[]
  boardPollVotes BoardPollVote[]
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model QuestionSet {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  coverImage  String?
  isPublic    Boolean  @default(false)
  
  questions   Question[]
  
  creatorId   String   @db.ObjectId
  creator     User     @relation(fields: [creatorId], references: [id])
  
  assignments Assignment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

type Question {
  id            String   @default(uuid())
  question      String
  image         String?
  timeLimit     Int      @default(20) // Seconds
  options       String[]
  optionTypes   String[] // "TEXT" | "IMAGE" | "MATH"
  questionType  String   @default("MULTIPLE_CHOICE") // "MULTIPLE_CHOICE" | "TYPING_ANSWER"
  correctAnswer Int
}

model ActiveGame {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  pin       String   @unique
  gameMode  String   // "GOLD_QUEST", etc.
  hostId    String
  settings  Json
  players   Json     // Serialized array of players
  questions Json     // Serialized questions
  startTime DateTime?
  state     Json?    // Game specific state (e.g. chests)
  updatedAt DateTime @updatedAt
}

model GameHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  hostId    String   @db.ObjectId
  gameMode  String
  pin       String?
  startedAt DateTime
  endedAt   DateTime @default(now())
  
  settings  Json
  players   Json
  
  host      User     @relation(fields: [hostId], references: [id])
}

// Classroom System Models

model Classroom {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  grade       String?
  image       String?
  theme       String?      @default("from-blue-400 to-cyan-500")
  emoji       String?      @default("🛡️")
  levelConfig Json?        // Stores rank names and min scores
  teacherId   String       @db.ObjectId
  teacher     User         @relation(fields: [teacherId], references: [id])
  students    Student[]
  skills      Skill[]
  assignments Assignment[]
  studentGroups StudentGroup[]
  attendanceRecords AttendanceRecord[]
  boards      Board[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  gamifiedSettings Json?    // Shared game state (Boss HP, classroom buffs, etc.)
}

model Student {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nickname    String?                // ชื่อเล่น
  avatar      String?                // Monster Seed/ID
  order       Int                    @default(0) // เลขที่ / position
  classId     String                 @db.ObjectId
  classroom   Classroom              @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId      String?                @db.ObjectId // Optional link to a Gmail/credentials User account
  user        User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  loginCode   String                 @unique @default(cuid()) // Unique code for student portal login
  points      Int                    @default(0)
  attendance  String                 @default("PRESENT") // PRESENT, ABSENT, LATE, LEFT_EARLY
  history     PointHistory[]
  submissions AssignmentSubmission[]
  attendanceRecords AttendanceRecord[]
  notifications Notification[]
  boardPosts    BoardPost[]
  boardComments BoardComment[]
  boardReactions BoardReaction[]
  boardPollVotes BoardPollVote[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  gameStats   Json?                  // { gold: 0, level: 1, inventory: [], ... }
  lastSyncTime DateTime?             @default(now()) // For idle calculation
}

model Skill {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  weight      Int       // +1, -1
  icon        String    // Icon identifier
  type        String    // POSITIVE, NEEDS_WORK
  classId     String    @db.ObjectId
  classroom   Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model StudentGroup {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  classId    String    @db.ObjectId
  classroom  Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentIds String[]  // Array of Student IDs in the group
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model PointHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String   @db.ObjectId
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skillId     String?  // Optional snapshot
  reason      String   // Snapshot of skill name
  value       Int
  timestamp   DateTime @default(now())
}

model Assignment {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  type        String                 @default("score") // score, checklist, quiz
  maxScore    Int                    @default(10)
  passScore   Int?
  deadline    DateTime?
  
  setId       String?                @db.ObjectId
  questionSet QuestionSet?           @relation(fields: [setId], references: [id])
  
  checklists  Json?
  quizData    Json?                  // snapshot of quiz questions if type=quiz
  visible     Boolean                @default(true)
  order       Int                    @default(0)
  classId     String                 @db.ObjectId
  classroom   Classroom              @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model AssignmentSubmission {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String     @db.ObjectId
  assignmentId   String     @db.ObjectId
  score          Int
  cheatingLogs   String[]
  submittedAt    DateTime   @default(now())
  
  student        Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
}

model AttendanceRecord {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String    @db.ObjectId
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId     String    @db.ObjectId
  classroom   Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
  status      String    // PRESENT, ABSENT, LATE, LEFT_EARLY
  date        DateTime  @default(now())
}

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId // For teachers
  studentId   String?  @db.ObjectId // For students
  title       String
  message     String
  type        String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR, ASSIGNMENT, POINT
  isRead      Boolean  @default(false)
  link        String?  
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  student     Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Board {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  classId     String      @db.ObjectId
  classroom   Classroom   @relation(fields: [classId], references: [id], onDelete: Cascade)
  posts       BoardPost[]
  settings    Json?       // For bg color, permissions, etc.
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model BoardPost {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  type        String         @default("text") // "text", "link", "file", "youtube", "poll", "album"
  title       String?
  content     String
  image       String?        // Main image or thumbnail
  color       String?        // e.g. "pink", "blue", "green"
  
  // Type specific fields
  linkUrl     String?
  fileUrl     String?
  fileName    String?
  videoUrl    String?
  videoName   String?
  youtubeId   String?
  pollQuestion String?
  pollOptions Json?         // Array of { text: string, id: string }
  pollClosed  Boolean        @default(false)
  albumImages Json?         // Array of image URLs
  
  boardId     String         @db.ObjectId
  board       Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  
  // Author can be a Student or a Teacher (User)
  authorStudentId String?    @db.ObjectId
  authorStudent   Student?   @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?    @db.ObjectId
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  
  comments    BoardComment[]
  reactions   BoardReaction[]
  pollVotes   BoardPollVote[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model BoardPollVote {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  optionId    String    // The ID of the option voted for
  postId      String    @db.ObjectId
  post        BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorStudentId String?    @db.ObjectId
  authorStudent   Student?   @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?    @db.ObjectId
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime  @default(now())
  
  @@unique([postId, authorStudentId, authorUserId])
}

model BoardComment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  postId      String    @db.ObjectId
  post        BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorStudentId String?    @db.ObjectId
  authorStudent   Student?   @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?    @db.ObjectId
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime  @default(now())
}

model BoardReaction {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  type        String    // e.g. "HEART", "STAR", "LIKE"
  postId      String    @db.ObjectId
  post        BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorStudentId String?    @db.ObjectId
  authorStudent   Student?   @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?    @db.ObjectId
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@unique([postId, authorStudentId, authorUserId, type])
}
