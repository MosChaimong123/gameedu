{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "outDir": "dist",
        "lib": [
            "es2019"
        ],
        "target": "es2019",
        "moduleResolution": "node",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "noEmit": false,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "server.ts",
        "src/**/*.ts"
    ]
}