generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER") // "USER", "ADMIN", "TEACHER"
  accounts      Account[]
  sessions      Session[]
  classrooms    Classroom[]
  studentProfiles Student[]
  gameHistories GameHistory[]
  
  username      String?   @unique
  school        String?
  createdAt     DateTime  @default(now())

  // Back-relations for Board functionality
  boardPosts    BoardPost[]
  boardComments BoardComment[]
  boardReactions BoardReaction[]
  boardPollVotes BoardPollVote[]
  notifications Notification[]
  questionSets  QuestionSet[]
  folders       Folder[]
  omrQuizzes    OMRQuiz[]   @relation("TeacherOMRQuizzes")

  // User Preferences & Settings
  settings      Json?     @default("{\"theme\":\"light\",\"sfxEnabled\":true,\"bgmEnabled\":true,\"language\":\"th\"}")

  // Subscription System
  plan          String?   @default("FREE")    // "FREE", "PLUS", "PRO"
  planStatus    String?   @default("INACTIVE") // "ACTIVE", "EXPIRED", "INACTIVE"
  planExpiry    DateTime?
  customerId    String?   // Stripe/Payment Provider Customer ID
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Gamification Models

model ActiveGame {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  pin       String   @unique
  gameMode  String   // e.g. "GOLD_QUEST", "CRYPTO_HACK"
  hostId    String   @db.ObjectId
  settings  Json     // Serialized game settings
  players   Json     // Serialized array of players
  questions Json     // Serialized questions
  startTime DateTime?
  state     Json?    // Game specific state (e.g. chests)
  updatedAt DateTime @updatedAt
}

model GameHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  hostId    String   @db.ObjectId
  setId     String?  @db.ObjectId
  gameMode  String
  pin       String?
  startedAt DateTime
  endedAt   DateTime @default(now())
  
  settings  Json
  players   Json
  
  host      User     @relation(fields: [hostId], references: [id])
}

// Classroom System Models

model Classroom {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  grade       String?
  image       String?
  theme       String?      @default("from-blue-400 to-cyan-500")
  emoji       String?      @default("🛡️")
  levelConfig Json?        // Stores rank names and min scores
  teacherId   String       @db.ObjectId
  teacher     User         @relation(fields: [teacherId], references: [id])
  students    Student[]
  skills      Skill[]
  assignments Assignment[]
  studentGroups StudentGroup[]
  attendanceRecords AttendanceRecord[]
  boards      Board[]
  omrQuizzes  OMRQuiz[]
  gamifiedSettings Json?   // Stores shop items, world boss status, etc.
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Student {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nickname    String?                // ชื่อเล่น
  avatar      String?                // Monster Seed/ID
  order       Int                    @default(0) // เลขที่ / position
  classId     String                 @db.ObjectId
  classroom   Classroom              @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId      String?                @db.ObjectId // Optional link to a Gmail/credentials User account
  user        User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  loginCode   String                 @unique @default(cuid()) // Unique code for student portal login
  points      Int                    @default(0)
  attendance  String                 @default("PRESENT") // PRESENT, ABSENT, LATE, LEFT_EARLY
  history     PointHistory[]
  submissions AssignmentSubmission[]
  attendanceRecords AttendanceRecord[]
  notifications Notification[]
  omrResults    OMRResult[]
  boardPosts    BoardPost[]
  boardComments BoardComment[]
  boardReactions BoardReaction[]
  boardPollVotes BoardPollVote[]
  items         StudentItem[]
  achievements  StudentAchievement[]
  questProgress Json?                  // { lastQuestDate: "", completedQuests: [] }
  challengesSent     StudentBattle[]   @relation("Challenger")
  challengesReceived StudentBattle[]   @relation("Defender")
  gameStats     Json?                  // RPG stats: { gold, xp, level, inventory... }
  stamina       Int                    @default(3) // Default 3 energy
  maxStamina    Int                    @default(3)
  mana          Int                    @default(50)
  lastStaminaRefill DateTime?           @default(now())
  lastSyncTime  DateTime?              // For idle calculations
  // Job Class System
  jobClass      String?                // "WARRIOR" | "MAGE" | "RANGER" | "HEALER" | "ROGUE"
  jobTier       String?                @default("BASE") // "BASE" | "ADVANCE" | "MASTER"
  advanceClass  String?                // e.g. "KNIGHT", "BERSERKER", "ARCHMAGE" ...
  jobSkills     Json?                  // string[] of unlocked skill IDs + passive IDs
  jobSelectedAt DateTime?
  materials     Material[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model PointHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  value     Int
  reason    String
  skillId   String?  @db.ObjectId
  timestamp DateTime @default(now())
}

model Skill {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  icon        String?
  type        String    @default("POSITIVE") // POSITIVE, NEEDS_WORK
  weight      Int       @default(1)
  classId     String    @db.ObjectId
  classroom   Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model Assignment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  visible     Boolean  @default(true)
  type        String   @default("standard") // "standard", "checklist", "quiz"
  checklists  Json?    // Array of { id, text, points }
  quizData    Json?    // { questions: [] }
  maxScore    Int      @default(100)
  passScore   Int?
  deadline    DateTime?
  order       Int      @default(0)
  
  classId     String   @db.ObjectId
  classroom   Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
  
  quizSetId   String?  @db.ObjectId
  quizSet     QuestionSet? @relation(fields: [quizSetId], references: [id], onDelete: SetNull)
  
  submissions AssignmentSubmission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AssignmentSubmission {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId String     @db.ObjectId
  studentId    String     @db.ObjectId
  score        Int        @default(0)
  content      String?    // Optional text/link submission
  cheatingLogs Json?      // Log of browser tab switches etc
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submittedAt  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([studentId, assignmentId])
}

model StudentGroup {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  classId   String   @db.ObjectId
  classroom Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentIds String[] @db.ObjectId
  createdAt DateTime @default(now())
}

model AttendanceRecord {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime
  classId   String   @db.ObjectId
  studentId String   @db.ObjectId
  status    String   // PRESENT, ABSENT, LATE, LEFT_EARLY
  classroom Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([date, studentId])
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String?  @db.ObjectId
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, DANGER
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Board {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  classId     String      @db.ObjectId
  classroom   Classroom   @relation(fields: [classId], references: [id], onDelete: Cascade)
  posts       BoardPost[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model BoardPost {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  images      String[]       // Array of URLs
  boardId     String         @db.ObjectId
  board       Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  
  authorStudentId String?    @db.ObjectId
  authorStudent   Student?   @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?    @db.ObjectId
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  
  // Additional media fields for varied post types
  type            String?    
  title           String?    
  image           String?    
  color           String?    
  linkUrl         String?    
  fileUrl         String?    
  fileName        String?    
  videoUrl        String?    
  videoName       String?    
  youtubeId       String?    
  
  comments    BoardComment[]
  reactions   BoardReaction[]
  poll        BoardPoll?
  pollVotes   BoardPollVote[]
  pollClosed  Boolean        @default(false)
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model BoardPoll {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  question    String
  options     Json           // Array of { id, text }
  postId      String         @unique @db.ObjectId
  post        BoardPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes       BoardPollVote[]
}

model BoardPollVote {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  optionId        String
  pollId          String      @db.ObjectId
  poll            BoardPoll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  
  postId          String?     @db.ObjectId
  post            BoardPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorStudentId String?     @db.ObjectId
  authorStudent   Student?    @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?     @db.ObjectId
  authorUser      User?       @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  

  @@unique([pollId, authorStudentId, authorUserId])
}

model BoardComment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  postId      String    @db.ObjectId
  post        BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorStudentId String?    @db.ObjectId
  authorStudent   Student?   @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?    @db.ObjectId
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime  @default(now())
}

model BoardReaction {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  type        String    // e.g. "HEART", "STAR", "LIKE"
  postId      String    @db.ObjectId
  post        BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorStudentId String?    @db.ObjectId
  authorStudent   Student?   @relation(fields: [authorStudentId], references: [id], onDelete: SetNull)
  authorUserId    String?    @db.ObjectId
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@unique([postId, authorStudentId, authorUserId, type])
}

model Item {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  price       Int      @default(0)
  type        String   // "WEAPON" | "ARMOR" | "HELMET" | "GLOVES" | "BOOTS" | "NECKLACE" | "RING"
  image       String?
  
  // RPG Stats
  baseHp      Int?     @default(0)
  baseAtk     Int?     @default(0)
  baseDef     Int?     @default(0)
  
  // Special Multipliers (0.05 = 5%, 1.0 = 100%)
  goldMultiplier      Float?   @default(0)
  bossDamageMultiplier Float?   @default(0)

  // Advanced Stats
  baseSpd     Int?      @default(0) // Speed / Agility
  baseCrit    Float?    @default(0) // Critical Rate (0 - 1.0)
  baseLuck    Float?    @default(0) // Luck (0 - 1.0)
  baseMag     Int?      @default(0) // Magic Power
  baseMp      Int?      @default(0) // Max Mana

  // Battle RPG System fields
  tier        String    @default("COMMON") // "COMMON" | "RARE" | "EPIC" | "LEGENDARY"
  slot        String?   // "HEAD" | "BODY" | "WEAPON" | "OFFHAND" | "GLOVES" | "BOOTS" | "ACCESSORY"
  setId       String?   // "DRAGON_SET" | "THUNDER_SET" | "SHADOW_SET" | "LEGENDARY_SET"
  effects     Json?     // string[] of effect IDs e.g. ["GOLD_FINDER", "LIFESTEAL"]
  xpMultiplier Float?   @default(0)
  
  // Stamina/Consumable Support
  currency        String    @default("GOLD") // "GOLD" | "POINTS"
  staminaRestore  Int?      @default(0)
  manaRestore     Int?      @default(0)
  hpRestorePercent Float?   @default(0) // 0.3 = +30% maxHp bonus at next battle start
  isPhoenix       Boolean?  @default(false) // Revive once with 50% HP at next battle
  buffAtk         Float?    @default(0) // 0.5 = ATK +50% at next battle start
  buffDef         Float?    @default(0) // 0.8 = DEF +80% at next battle start
  buffSpd         Float?    @default(0) // 1.0 = SPD +100% at next battle start
  buffGoldMinutes Int?      @default(0) // Gold ×2 for N minutes (stored as expiry timestamp)
  buffXpMinutes   Int?      @default(0) // XP ×2 for N minutes
  isTransmute     Boolean?  @default(false) // Converts 5 COMMON materials → 1 RARE material
  isLevelUp       Boolean?  @default(false) // Instantly grants +1 level (XP resets to 0)
  
  students    StudentItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudentItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String   @db.ObjectId
  itemId      String   @db.ObjectId
  quantity    Int      @default(1)
  isEquipped  Boolean  @default(false)
  enhancementLevel Int   @default(0)
  
  // Instance stats (Calculated based on base stats + enhancement)
  hp          Int      @default(0)
  atk         Int      @default(0)
  def         Int      @default(0)
  spd         Int      @default(0)
  crit        Float    @default(0)
  luck        Float    @default(0)
  mag         Int      @default(0)
  mp          Int      @default(0)
  
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, itemId])
}

model Material {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String   // One of 12 material types
  quantity  Int      @default(1)

  @@unique([studentId, type])
}

model StudentAchievement {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String   @db.ObjectId
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievementId  String   // e.g. "BOSS_SLAYER", "FIRST_ITEM"
  goldRewarded   Int      @default(0)
  unlockedAt     DateTime @default(now())

  @@unique([studentId, achievementId])
}

model StudentBattle {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  challengerId    String   @db.ObjectId
  defenderId      String   @db.ObjectId
  challenger      Student  @relation("Challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  defender        Student  @relation("Defender", fields: [defenderId], references: [id], onDelete: Cascade)
  status          String   @default("PENDING") // PENDING, ACCEPTED, DECLINED, COMPLETED
  classId         String?  @db.ObjectId
  betAmount       Int      @default(0)
  challengerRoll  Int?
  defenderRoll    Int?
  winnerId        String?  @db.ObjectId
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuestionSet {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  isPublic    Boolean  @default(false)
  coverImage  String?
  creatorId   String   @db.ObjectId
  creator     User     @relation(fields: [creatorId], references: [id])
  folderId    String?  @db.ObjectId
  folder      Folder?  @relation(fields: [folderId], references: [id])
  questions   Json     // Array of questions
  assignments Assignment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Folder {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  
  creatorId   String   @db.ObjectId
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  parentFolderId String? @db.ObjectId
  // Note: Nested folders can be added later if needed by self-referencing
  
  questionSets QuestionSet[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OMRQuiz {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  questionCount Int    @default(20)
  answerKey   Json     // Map of question numbers to correct answers { "1": "A", "2": "B" ... }
  
  classId     String?  @db.ObjectId
  classroom   Classroom? @relation(fields: [classId], references: [id])
  
  teacherId   String   @db.ObjectId
  teacher     User     @relation("TeacherOMRQuizzes", fields: [teacherId], references: [id])
  
  results     OMRResult[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OMRResult {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  quizId      String   @db.ObjectId
  quiz        OMRQuiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  studentId   String?  @db.ObjectId
  student     Student? @relation(fields: [studentId], references: [id])
  
  studentName String?  // Fallback for anonymous scanning
  score       Int
  total       Int
  answers     Json     // The student's detected answers
  
  scannedAt   DateTime @default(now())
}
