{
  "name": "gamedu",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "tsc --project tsconfig.server.json",
    "dev": "node run-server.cjs",
    "dev:clear-lock": "rimraf .next/dev/lock",
    "dev:fresh": "rimraf .next && npm run dev",
    "clean": "rimraf .next dist",
    "build": "npm run clean && npx prisma generate && next build && tsc --project tsconfig.server.json",
    "postinstall": "prisma generate",
    "start": "node run-server.cjs",
    "lint": "eslint",
    "check:i18n": "node scripts/check-i18n-hardcoded.mjs",
    "check:i18n:strict": "node scripts/check-i18n-hardcoded.mjs --strict",
    "check:phase1": "node scripts/check-phase1-readiness.mjs",
    "load:phase1:http": "node scripts/phase1-http-load-smoke.mjs",
    "test": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.mts --pool threads",
    "test:unit": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.mts --pool threads --exclude src/lib/socket/__tests__/**/*.integration.test.ts",
    "test:integration": "node ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.mts --pool threads",
    "test:watch": "node ./node_modules/vitest/vitest.mjs --config vitest.config.mts --pool threads",
    "test:e2e:asn": "playwright test -c playwright.asn.config.ts",
    "test:e2e:negamon-reward": "playwright test -c playwright.asn.config.ts -g \"Negamon reward re-sync smoke\"",
    "test:e2e:asn:headed": "playwright test -c playwright.asn.config.ts --headed",
    "test:e2e:asn:install": "playwright install chromium",
    "governance:check": "node scripts/check-governance.mjs",
    "smoke:build": "node scripts/smoke-build.mjs",
    "pr:body:asn": "node scripts/pr-body-asn-prepare.mjs",
    "db:seed": "npx prisma db seed",
    "db:push": "npx prisma db push",
    "prisma:regen": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prisma-generate-unlock.ps1",
    "db:cleanup-rpg": "node scripts/cleanup-rpg-data.mjs",
    "db:cleanup-rpg:dry-run": "node scripts/cleanup-rpg-data.mjs --dry-run",
    "user:set-role": "node scripts/promote-user-role.mjs",
    "db:backfill-email-verified": "node scripts/backfill-email-verified.mjs",
    "billing:stripe-listen": "node scripts/stripe-listen.mjs",
    "billing:stripe-print-secret": "node scripts/stripe-print-webhook-secret.mjs",
    "billing:stripe-trigger-checkout": "node scripts/stripe-trigger-checkout-completed.mjs"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.26.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "mongodb": "^7.1.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.7.0",
    "resend": "^6.12.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "use-sound": "^5.0.0",
    "youtube-transcript": "^1.3.0",
    "youtube-transcript-api": "^3.0.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.29",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "fast-check": "^4.6.0",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "postcss": "8.5.13"
  }
}
