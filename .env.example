# --- MongoDB (Prisma datasource in prisma/schema.prisma) ---
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority"

# Render: ดู render.yaml (build + preDeploy prisma db push). คัดลอกค่าส่วนใหญ่ไปใส่ Dashboard → Environment

# Public URL of the app (no trailing slash). On Render: https://your-service-name.onrender.com
NEXT_PUBLIC_APP_URL="https://your-app-name.onrender.com"

# Next Auth / Auth.js
NEXTAUTH_URL="https://your-app-name.onrender.com"
NEXTAUTH_SECRET="your-super-secret-key"
AUTH_SECRET="your-super-secret-key"
# Required behind Render / reverse proxy (also set in render.yaml)
AUTH_TRUST_HOST="true"

# Google OAuth — optional; if both are unset or empty, only credentials login is used
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# Email verification (Resend) — optional in dev (link is logged to console). Required in production for signup emails.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="GameEdu <notify@yourdomain.com>"

# Socket.io (browser connects here; same origin as the app on Render)
NEXT_PUBLIC_SOCKET_URL="https://your-app-name.onrender.com"
# Production: comma-separated allowed origins (defaults to NEXTAUTH_URL if unset). Dev uses reflected origin.
# SOCKET_IO_CORS_ORIGIN="https://your-app-name.onrender.com"

# Optional: Port (Render sets PORT automatically)
PORT=3000
# auto: production uses Mongo for shared rate limits; dev/test use memory
RATE_LIMIT_STORE="auto"
AUDIT_LOG_SINK="auto"
HEALTHCHECK_DB_TIMEOUT_MS=3000

# Admin secret (required to create an ADMIN account)
ADMIN_SECRET="your-admin-secret-key-here"

# AI (optional — generate-questions API)
# GEMINI_API_KEY="..."

# Optional quiz review default: end_only | never
# QUIZ_REVIEW_MODE="end_only"

# --- Stripe billing (PLUS subscription self-serve) ---
# Copy actual values into .env.local (gitignored). Use Price IDs (price_...) from each price row — not Product ID (prod_...).
# Create Products/Prices in Stripe Dashboard; paste Price IDs (price_...) below.
# STRIPE_SECRET_KEY="sk_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..." # optional until using Stripe.js
# STRIPE_PRICE_PLUS_MONTHLY="price_..."
# STRIPE_PRICE_PLUS_YEARLY="price_..."
# Local webhooks: ใส่ STRIPE_SECRET_KEY แล้วรัน npm run billing:stripe-listen (ไม่ต้อง stripe login)
# เอา whsec ใส่ STRIPE_WEBHOOK_SECRET: npm run billing:stripe-print-secret
#
# Thai-local payments (PromptPay / bank apps): typically via a Thailand PSP (e.g. Omise, 2C2P)
# with its own checkout + webhook — mirror the same User.plan/planExpiry updates as Stripe.
# BILLING_THAI_PROVIDER: unset | none = hide Thai channel; mock = dev placeholder + upgrade UI;
#   omise = real PromptPay via Omise (needs OMISE_SECRET_KEY + webhook in Omise dashboard).
# BILLING_THAI_WEBHOOK_SECRET: Bearer for POST /api/webhooks/billing/mock only (not used for Omise).
# OMISE_SECRET_KEY="skey_test_..."  # Dashboard → Keys (secret)
# NEXT_PUBLIC_OMISE_PUBLIC_KEY="pkey_test_..."  # optional until Omise.js on client; can mirror OMISE_PUBLIC_KEY
# OMISE_PLUS_MONTHLY_SATANG="29000"   # THB amount × 100 (satang); min 2000
# OMISE_PLUS_YEARLY_SATANG="348000"   # optional; defaults to monthly × 12 if unset
# Omise Dashboard → Webhooks → URL: https://YOUR_DOMAIN/api/webhooks/billing/omise (same path test/live by key)
# Local dev: webhook may be unreachable — after payment, returning to ?checkout=omise_return runs POST /api/billing/omise/reconcile using a short-lived cookie set at /api/billing/thai/start.
# BILLING_THAI_PROVIDER="mock"
# BILLING_THAI_PROVIDER="omise"
# BILLING_THAI_WEBHOOK_SECRET="dev-only-secret"
