{
  "name": "gamedu",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register --project tsconfig.server.json server.ts",
    "clean": "rimraf .next dist",
    "build": "npm run clean && npx prisma generate && next build && tsc --project tsconfig.server.json",
    "postinstall": "prisma generate",
    "start": "node dist/server.js",
    "lint": "eslint",
    "test": "node ./node_modules/vitest/vitest.mjs run --configLoader native --config vitest.config.mts --pool threads",
    "test:watch": "node ./node_modules/vitest/vitest.mjs --configLoader native --config vitest.config.mts --pool threads",
    "db:seed": "npx prisma db seed",
    "db:push": "npx prisma db push",
    "db:cleanup-rpg": "node scripts/cleanup-rpg-data.mjs"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.26.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "mongodb": "^7.1.0",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "use-sound": "^5.0.0",
    "xlsx": "^0.18.5",
    "youtube-transcript": "^1.3.0",
    "youtube-transcript-api": "^3.0.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.29",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "fast-check": "^4.6.0",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.0"
  }
}
